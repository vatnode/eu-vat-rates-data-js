{
  "name": "eu-vat-rates-data",
  "version": "2026.3.26",
  "description": "VAT rates for 44 European countries — EU-27 plus Norway, Switzerland, UK, and more. Checked daily from EC TEDB, published automatically when rates change.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./data": "./data/eu-vat-rates-data.json"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "node --test test.js"
  },
  "keywords": [
    "vat",
    "eu",
    "european-union",
    "tax",
    "rates",
    "europe",
    "vat-rates",
    "eu-vat",
    "vat-moss",
    "digital-services-tax",
    "billing",
    "e-commerce",
    "fintech",
    "invoice",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://github.com/vatnode/eu-vat-rates-data-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vatnode/eu-vat-rates-data-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/rogulia"
  }
}
